---
import DarkModeToggle from "../islands/DarkModeToggle.tsx";
import SearchToggle from "../islands/SearchToggle.tsx";

const currentPath = Astro.url.pathname;

const navLinks = [
  { name: "Home", href: "/" },
  { name: "Research", href: "/research" },
  { name: "Publications", href: "/publications" },
  { name: "Enzo-Abyss", href: "/software" },
  { name: "Readea", href: "/arxiv-app" },
  { name: "About", href: "/about" },
  { name: "Contact", href: "/contact" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<nav class="bg-card border-b border-border sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 md:px-6 flex items-center justify-between h-16">
    <!-- Brand -->
    <a href="/" class="text-xl font-bold text-foreground hover:text-foreground no-underline">
      Yongseok Jo
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-3 py-2 text-sm font-medium transition-colors duration-150 hover:bg-muted rounded-md min-h-[48px] flex items-center",
            isActive(link.href)
              ? "border-b-2 border-accent text-foreground"
              : "text-muted-foreground hover:text-foreground",
          ]}
        >
          {link.name}
        </a>
      ))}
      <div class="ml-2">
        <SearchToggle client:load />
      </div>
      <div class="ml-2">
        <DarkModeToggle client:load />
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center h-12 w-12 text-foreground"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block px-3 py-3 text-sm font-medium transition-colors duration-150 hover:bg-muted rounded-md min-h-[48px] flex items-center",
            isActive(link.href)
              ? "border-l-2 border-accent text-foreground"
              : "text-muted-foreground hover:text-foreground",
          ]}
        >
          {link.name}
        </a>
      ))}
      <div class="px-3 py-2">
        <SearchToggle client:load />
      </div>
      <div class="px-3 py-2">
        <DarkModeToggle client:load />
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(isOpen));
    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  });
</script>
