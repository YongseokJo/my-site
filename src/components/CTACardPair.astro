---
// CTACardPair: Two side-by-side CTA cards for Simulation Package and ArXiv App.
// Uses shadcn Card components rendered statically (no client directive needed).
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "../components/ui/card";
import { Button } from "../components/ui/button";
---
<section class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <!-- Simulation Package Card -->
  <Card className="border border-border">
    <CardHeader>
      <div class="mb-2">
        <!-- Lucide Telescope icon (inline SVG) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="m10.065 12.493-6.18 1.318a.934.934 0 0 1-1.108-.702l-.537-2.15a1.07 1.07 0 0 1 .691-1.265l13.504-4.44"/><path d="m13.56 11.747 4.332-.924"/><path d="m16 21-3.105-6.21"/><path d="M16.485 5.94a2 2 0 0 1 1.455-2.425l1.09-.272a1 1 0 0 1 1.212.727l1.515 6.06a1 1 0 0 1-.727 1.213l-1.09.272a2 2 0 0 1-2.425-1.455z"/><path d="m6.158 8.633 1.114 4.456"/><path d="m8 21 3.105-6.21"/></svg>
      </div>
      <CardTitle className="text-base font-bold">Simulation Package</CardTitle>
      <CardDescription className="text-base text-muted-foreground">
        Explore cosmological simulation tools for galaxy formation and star cluster evolution.
      </CardDescription>
    </CardHeader>
    <CardContent>
      <a href="/software">
        <Button className="bg-primary text-primary-foreground hover:bg-primary/90">
          Explore Simulations
        </Button>
      </a>
    </CardContent>
  </Card>

  <!-- ArXiv App Card -->
  <Card className="border border-border">
    <CardHeader>
      <div class="mb-2">
        <!-- Lucide Newspaper icon (inline SVG) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
      </div>
      <CardTitle className="text-base font-bold">ArXiv App</CardTitle>
      <CardDescription className="text-base text-muted-foreground">
        Browse and organize arXiv papers with an intuitive reading experience.
      </CardDescription>
    </CardHeader>
    <CardContent>
      <a href="/arxiv-app">
        <Button className="bg-primary text-primary-foreground hover:bg-primary/90">
          Try ArXiv App
        </Button>
      </a>
    </CardContent>
  </Card>
</section>
