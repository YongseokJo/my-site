---
import DeviceMockupPlaceholder from "./DeviceMockupPlaceholder.astro";
---
<section class="w-full bg-[#0a0e1a] relative">
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(10, 14, 26, 0.7), rgba(10, 14, 26, 0.95));"
  ></div>
  <div class="relative z-10 max-w-[1100px] mx-auto px-4 md:px-6 lg:px-8 py-20 md:py-24 text-center">
    <h1 class="text-4xl font-bold text-[#e2e8f0]">Readea</h1>
    <p class="text-base text-[#94a3b8] mt-4 mb-8">
      A modern reading experience for arXiv papers on macOS and iOS
    </p>
    <div class="mb-8 grid grid-cols-1 md:grid-cols-2 gap-6 relative">
      <div class="relative cursor-zoom-in readea-zoomable">
        <img src="/images/readea1.png" alt="Readea app screenshot - dark theme" class="rounded-xl shadow-2xl w-full h-auto readea-img-a" />
        <img src="/images/readea1_1.png" alt="Readea app screenshot - light theme" class="rounded-xl shadow-2xl w-full h-auto readea-img-b absolute inset-0 opacity-0" />
      </div>
      <div class="relative cursor-zoom-in readea-zoomable">
        <img src="/images/readea2.png" alt="Readea app screenshot 2 - dark theme" class="rounded-xl shadow-2xl w-full h-auto readea-img-a" />
        <img src="/images/readea2_1.png" alt="Readea app screenshot 2 - light theme" class="rounded-xl shadow-2xl w-full h-auto readea-img-b absolute inset-0 opacity-0" />
      </div>
    </div>

    <!-- Zoom overlay -->
    <div id="zoom-overlay" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center cursor-zoom-out" style="display:none;">
      <img id="zoom-img" src="" alt="Zoomed screenshot" class="max-w-[90vw] max-h-[90vh] rounded-xl shadow-2xl" />
    </div>
    <a
      href="/contact"
      class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground font-medium rounded-lg hover:opacity-90 transition-opacity"
    >
      Contact for Beta Access
    </a>
  </div>
</section>

<style>
  .readea-img-a, .readea-img-b {
    transition: opacity 1s ease-in-out;
  }
</style>

<script>
  setInterval(() => {
    document.querySelectorAll('.readea-img-a').forEach(el => {
      el.classList.toggle('opacity-0');
    });
    document.querySelectorAll('.readea-img-b').forEach(el => {
      el.classList.toggle('opacity-0');
    });
  }, 4000);

  // Zoom on click
  const overlay = document.getElementById('zoom-overlay');
  const zoomImg = document.getElementById('zoom-img') as HTMLImageElement;

  document.querySelectorAll('.readea-zoomable').forEach(container => {
    container.addEventListener('click', () => {
      // Find the visible image (the one without opacity-0)
      const imgs = container.querySelectorAll('img');
      let visibleSrc = '';
      imgs.forEach(img => {
        if (!img.classList.contains('opacity-0')) {
          visibleSrc = img.src;
        }
      });
      if (visibleSrc && overlay && zoomImg) {
        zoomImg.src = visibleSrc;
        overlay.style.display = 'flex';
      }
    });
  });

  overlay?.addEventListener('click', () => {
    if (overlay) overlay.style.display = 'none';
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay) overlay.style.display = 'none';
  });
</script>
