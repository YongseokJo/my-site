---
interface Props {
  icon?: string;
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<div class="bg-card border border-border rounded-lg p-6 transition-colors duration-150 hover:border-muted-foreground">
  <div class="text-primary mb-3" aria-hidden="true">
    <slot />
  </div>
  <h3 class="text-base font-bold">{title}</h3>
  <p class="text-sm text-muted-foreground mt-1">{description}</p>
</div>
