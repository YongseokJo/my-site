---
// CosmicHero: Full-width hero with deep space background image and dark gradient overlay.
// Hero text is always light-on-dark regardless of site theme mode.
---
<section
  class="relative w-full py-12 md:py-16 md:pt-20 overflow-hidden"
  style="background-color: #0a0e1a;"
>
  <!-- Background image -->
  <div
    class="absolute inset-0"
    style="background-image: url('/images/bg.jpg'); background-size: cover; background-position: center;"
    role="img"
    aria-label="Deep space cosmic background"
  ></div>

  <!-- Gradient overlay (always dark, both themes) -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(10, 14, 26, 0.7), rgba(10, 14, 26, 0.95));"
  ></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center text-center px-4">
    <h1
      class="max-w-[600px] text-4xl font-bold leading-[1.15]"
      style="color: #e2e8f0;"
    >
      First Star Clusters & Black Holes in the Early Universe
    </h1>
    <p
      class="mt-4 text-base font-normal leading-relaxed"
      style="color: #94a3b8;"
    >
      Computational Astrophysicist & ML Researcher
    </p>
  </div>
</section>
