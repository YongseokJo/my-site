---
import DeviceMockupPlaceholder from "./DeviceMockupPlaceholder.astro";

interface Props {
  stepNumber: number;
  title: string;
  description: string;
  hasScreenshot?: boolean;
}

const { stepNumber, title, description, hasScreenshot = false } = Astro.props;
---
<div class="space-y-3">
  <div class="flex items-center gap-3">
    <div class="bg-primary text-primary-foreground w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shrink-0">
      {stepNumber}
    </div>
    <h3 class="text-base font-bold">{title}</h3>
  </div>
  <p class="text-base text-foreground ml-11">{description}</p>
  {hasScreenshot && (
    <div class="ml-11">
      <div class="bg-muted rounded-2xl border border-border flex items-center justify-center w-full max-w-md h-[240px]" role="img" aria-label="App screenshot placeholder">
        <span class="text-muted-foreground text-sm">Screenshot coming soon</span>
      </div>
    </div>
  )}
</div>
