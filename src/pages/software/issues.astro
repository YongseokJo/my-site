---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import IssueForm from "../../islands/IssueForm.tsx";
import IssueList from "../../islands/IssueList.tsx";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=" + encodeURIComponent(Astro.url.pathname));
}

const { data: profile } = await Astro.locals.supabase
  .from("profiles")
  .select("role, approved, display_name")
  .eq("id", user.id)
  .single();

if (!profile?.approved) {
  return Astro.redirect("/pending-approval");
}

const canSubmit = ["admin", "co_admin", "pi_mentor", "developer"].includes(profile.role);
---

<BaseLayout title="To-Do / Issues - Enzo-Abyss">
  <div class="space-y-8">
    <div>
      <a href="/software" class="text-sm text-muted-foreground hover:text-foreground">
        &larr; Back to Software
      </a>
    </div>

    <div>
      <h1 class="text-2xl font-bold mb-2">To-Do / Issues</h1>
      <p class="text-muted-foreground">
        Report and track to-do items and issues related to the Enzo-Abyss simulation package.
      </p>
    </div>

    {canSubmit && (
      <section>
        <IssueForm client:load />
      </section>
    )}

    <section>
      <h2 class="text-lg font-semibold mb-4">All To-Do / Issues</h2>
      <IssueList client:load userId={user.id} userRole={profile.role} />
    </section>
  </div>
</BaseLayout>

