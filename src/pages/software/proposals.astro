---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import ProposalForm from "../../islands/ProposalForm.tsx";
import ProposalList from "../../islands/ProposalList.tsx";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=" + encodeURIComponent(Astro.url.pathname));
}

const { data: profile } = await Astro.locals.supabase
  .from("profiles")
  .select("role, approved, display_name")
  .eq("id", user.id)
  .single();

if (!profile?.approved) {
  return Astro.redirect("/pending-approval");
}

const canSubmit = ["admin", "pi_mentor", "developer"].includes(profile.role);
---

<BaseLayout title="Proposals - Enzo-Abyss">
  <div class="space-y-8">
    <div>
      <a href="/software" class="text-sm text-muted-foreground hover:text-foreground">
        &larr; Back to Software
      </a>
    </div>

    <div>
      <h1 class="text-2xl font-bold mb-2">Project Proposals</h1>
      <p class="text-muted-foreground">
        Submit and review proposals for projects related to the Enzo-Abyss simulation package.
        Proposals are reviewed by PIs and mentors.
      </p>
    </div>

    {canSubmit && (
      <section>
        <ProposalForm client:load />
      </section>
    )}

    <section>
      <h2 class="text-lg font-semibold mb-4">All Proposals</h2>
      <ProposalList client:load userId={user.id} userRole={profile.role} />
    </section>
  </div>
</BaseLayout>
