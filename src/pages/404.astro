---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found">
  <div class="py-16 text-center">
    <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-muted-foreground mb-8">The page you're looking for doesn't exist. Return to the homepage to continue.</p>
    <a href="/" class="text-primary hover:underline">Return to homepage</a>
  </div>
</BaseLayout>
