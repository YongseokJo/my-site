---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FeedbackForm from "../../islands/FeedbackForm.tsx";
---
<BaseLayout title="Send Feedback" description="Help improve Readea with your suggestions and bug reports.">
  <Breadcrumb items={[
    { label: "Readea", href: "/arxiv-app" },
    { label: "Feedback" },
  ]} />
  <h1 class="text-2xl font-bold mt-6 mb-2">Send Feedback</h1>
  <p class="text-base text-muted-foreground mb-8">Help improve Readea with your suggestions</p>
  <FeedbackForm client:load />
</BaseLayout>
