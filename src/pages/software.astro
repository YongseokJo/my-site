---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import ProductHeader from "../components/ProductHeader.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import FeatureCard from "../components/FeatureCard.astro";
import CodeBlock from "../components/CodeBlock.astro";
import UserMenu from "../islands/UserMenu.tsx";

let initialUser: { email: string; displayName: string } | null = null;
const user = Astro.locals.user;
if (user) {
  const supabase = Astro.locals.supabase;
  const { data: profile } = await supabase
    .from("profiles")
    .select("display_name, approved")
    .eq("id", user.id)
    .single();
  if (profile?.approved) {
    return Astro.redirect("/dashboard");
  }
  initialUser = {
    email: user.email ?? "",
    displayName: profile?.display_name ?? "",
  };
}
---
<BaseLayout title="Enzo-Abyss" description="Enzo-Abyss: a cosmological simulation framework for studying the formation of first star clusters and black holes in the early universe.">

  <ProductHeader name="Enzo-Abyss" tagline="Cosmological simulation framework for studying first star clusters and black holes" />

  <div class="flex justify-end mb-6">
    <UserMenu client:load initialUser={initialUser} />
  </div>

  <FeatureGrid sectionTitle="Features">
    <FeatureCard title="Enzo" description="A community-developed adaptive mesh refinement (AMR) code for multi-physics cosmological hydrodynamic simulations, combining Eulerian hydrodynamics with dark matter N-body dynamics, radiative cooling, and star formation physics.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="7" height="7" x="14" y="3" rx="1" />
        <path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Direct N-body Dynamics" description="Solves gravitational equations of motion for N particles without approximations, calculating exact pairwise interactions. Essential for modeling star cluster dynamics and close-encounter interactions at high fidelity.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3" />
        <circle cx="19" cy="5" r="2" />
        <circle cx="5" cy="19" r="2" />
        <path d="M10.4 21.9a10 10 0 0 0 9.941-15.416" />
        <path d="M13.6 2.1a10 10 0 0 0-9.941 15.416" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Star-by-Star Physics" description="Tracks individual stars throughout their lifecycles at parsec-scale resolution within live cosmological simulations, modeling star-by-star chemical enrichment, feedback, and interactions in early galaxy formation environments.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Robust Black Hole Physics" description="AI-powered black hole physics informed by general-relativistic magnetohydrodynamic (GRMHD) simulations. Leveraging machine learning to model black hole accretion, feedback, and jet dynamics with unprecedented physical accuracy.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2a14.5 14.5 0 0 0 0 20a14.5 14.5 0 0 0 0-20" />
      </svg>
    </FeatureCard>
  </FeatureGrid>

  <h2 class="text-2xl font-bold mb-6 mt-12">Documentation</h2>
  <p class="text-muted-foreground">To be updated.</p>

</BaseLayout>
