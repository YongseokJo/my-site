---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductHeader from "../components/ProductHeader.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import FeatureCard from "../components/FeatureCard.astro";
import CodeBlock from "../components/CodeBlock.astro";
---
<BaseLayout title="Enzo-Abyss" description="Enzo-Abyss: a cosmological simulation framework for studying the formation of first star clusters and black holes in the early universe.">

  <ProductHeader name="Enzo-Abyss" tagline="Cosmological simulation framework for studying first star clusters and black holes" />

  <FeatureGrid sectionTitle="Features">
    <FeatureCard title="Adaptive Mesh Refinement" description="Multi-level grid refinement for resolving small-scale structure within large cosmological volumes.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="7" height="7" x="14" y="3" rx="1" />
        <path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3" />
      </svg>
    </FeatureCard>
    <FeatureCard title="N-body + Hydrodynamics" description="Self-consistent hybrid approach coupling gravitational N-body dynamics with hydrodynamic gas evolution.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3" />
        <circle cx="19" cy="5" r="2" />
        <circle cx="5" cy="19" r="2" />
        <path d="M10.4 21.9a10 10 0 0 0 9.941-15.416" />
        <path d="M13.6 2.1a10 10 0 0 0-9.941 15.416" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Star Formation & Feedback" description="Sub-grid models for star formation, supernova feedback, and chemical enrichment in early universe environments.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Black Hole Physics" description="Formation and growth of massive black holes with accretion and feedback processes in primordial halos.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Scalable Performance" description="Optimized for high-performance computing clusters with efficient parallel decomposition.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
      </svg>
    </FeatureCard>
    <FeatureCard title="Analysis Toolkit" description="Built-in tools for halo finding, merger tree construction, and visualization of simulation outputs.">
      <svg class="size-6 text-primary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v16a2 2 0 0 0 2 2h16" />
        <path d="M7 16l4-8 4 4 4-6" />
      </svg>
    </FeatureCard>
  </FeatureGrid>

  <h2 class="text-2xl font-bold mb-6 mt-12">Quick Start</h2>

  <div class="mb-6">
    <p class="text-base mb-3 font-medium">Step 1: Clone the repository</p>
    <CodeBlock code="git clone https://github.com/enzo-project/enzo-abyss.git" language="bash" />
  </div>

  <div class="mb-6">
    <p class="text-base mb-3 font-medium">Step 2: Configure and build</p>
    <CodeBlock code="cd enzo-abyss && ./configure && make" language="bash" />
  </div>

  <div class="mb-6">
    <p class="text-base mb-3 font-medium">Step 3: Run a test simulation</p>
    <CodeBlock code="./bin/enzo TestProblem.enzo" language="bash" />
  </div>

  <a href="/software/install" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground font-medium rounded-lg hover:opacity-90 transition-opacity mt-4">Get Started</a>

  <h2 class="text-2xl font-bold mb-6 mt-12">Documentation</h2>

  <div class="space-y-1">
    <a href="/software/install" class="flex items-center gap-2 text-base text-primary hover:underline transition-all duration-150 py-2">
      Installation
      <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
    <a href="/software/usage" class="flex items-center gap-2 text-base text-primary hover:underline transition-all duration-150 py-2">
      Usage Guide
      <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </a>
  </div>

</BaseLayout>
